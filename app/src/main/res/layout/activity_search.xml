<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:fitsSystemWindows="true"
    android:background="@color/background">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/surface">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <androidx.appcompat.widget.SearchView
                android:id="@+id/searchView"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                app:iconifiedByDefault="false"
                app:queryHint="File names, PDF text, places…" />

            <ImageButton
                android:id="@+id/btnStats"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:src="@drawable/ic_info"
                android:tint="@color/on_surface"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Stats" />
        </LinearLayout>
    </com.google.android.material.appbar.MaterialToolbar>

    <!-- Shown over the results grid when browsing/searching a place: "📍 Place · N photos". -->
    <TextView
        android:id="@+id/tvResultsHeader"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="12dp"
        android:textColor="@color/on_surface"
        android:textSize="14sp"
        android:textStyle="bold"
        android:background="@color/surface"
        android:visibility="gone" />

    <!-- Browse header (label + sort + drill breadcrumb); shown while browsing places. -->
    <LinearLayout
        android:id="@+id/browseHeader"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="10dp"
        android:paddingBottom="4dp"
        android:focusable="true"
        android:focusableInTouchMode="true"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/tvPlacesLabel"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Places in your photos"
                android:textColor="@color/on_surface_variant"
                android:textSize="13sp" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chipSort"
                style="@style/Widget.MaterialComponents.Chip.Choice"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Sort: most photos" />
        </LinearLayout>

        <!-- Option B drill path, e.g. "‹ United States › California" — tap to go up a level. -->
        <TextView
            android:id="@+id/tvBreadcrumb"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:padding="6dp"
            android:textColor="@color/primary"
            android:textSize="14sp"
            android:visibility="gone" />
    </LinearLayout>

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <!-- Hosts photo results (grid) AND the Option-C place tree (linear), via adapter swap. -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recyclerView"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clipToPadding="false"
            android:padding="2dp" />

        <!-- Option A / B chips (scrollable). -->
        <androidx.core.widget.NestedScrollView
            android:id="@+id/chipScroll"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:visibility="gone">

            <com.google.android.material.chip.ChipGroup
                android:id="@+id/chipPlaces"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="16dp"
                app:chipSpacing="6dp"
                app:singleLine="false" />
        </androidx.core.widget.NestedScrollView>

        <TextView
            android:id="@+id/tvEmpty"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:gravity="center"
            android:textColor="@color/on_surface_variant"
            android:textSize="15sp"
            android:text="Search file names\nand text inside PDFs" />

        <!-- Multi-select action bar — appears when results are long-pressed to act on photos. -->
        <LinearLayout
            android:id="@+id/selectionBar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom"
            android:orientation="vertical"
            android:background="@color/selection_bar"
            android:padding="12dp"
            android:elevation="8dp"
            android:visibility="gone">
            <TextView
                android:id="@+id/tvSelectionCount"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="@color/on_surface"
                android:text="0 selected" />
            <!-- Icon actions, matching the gallery/viewer glyphs. Share + Delete always show;
                 Rename / Switch Album / To gallery appear only on a single selection. Delete is
                 pushed to the right and red-tinted to set the destructive action apart. -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnShareSelected"
                    style="@style/Widget.Material3.Button.IconButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    app:icon="@drawable/ic_share"
                    app:iconTint="@color/on_surface"
                    android:contentDescription="Share"
                    android:tooltipText="Share" />
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnRenameSelected"
                    style="@style/Widget.Material3.Button.IconButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    app:icon="@drawable/ic_rename"
                    app:iconTint="@color/on_surface"
                    android:contentDescription="Rename"
                    android:tooltipText="Rename" />
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnMoveSelected"
                    style="@style/Widget.Material3.Button.IconButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    app:icon="@drawable/ic_swap"
                    app:iconTint="@color/on_surface"
                    android:contentDescription="Switch album"
                    android:tooltipText="Switch album" />
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnGallerySelected"
                    style="@style/Widget.Material3.Button.IconButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    app:icon="@drawable/ic_open_gallery"
                    app:iconTint="@color/on_surface"
                    android:contentDescription="Show in gallery"
                    android:tooltipText="Show in gallery" />
                <Space
                    android:layout_width="0dp"
                    android:layout_height="1dp"
                    android:layout_weight="1" />
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnDeleteSelected"
                    style="@style/Widget.Material3.Button.IconButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    app:icon="@drawable/ic_delete"
                    app:iconTint="@color/delete_red"
                    android:contentDescription="Delete"
                    android:tooltipText="Delete" />
            </LinearLayout>
        </LinearLayout>
    </FrameLayout>
</LinearLayout>
