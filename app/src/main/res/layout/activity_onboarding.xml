<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true"
    android:background="@color/background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="20dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="How curating works"
        android:textColor="@color/on_surface"
        android:textSize="22sp"
        android:textStyle="bold" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:lineSpacingExtra="2dp"
        android:text="Review a month, hide it, and it steps out of your way — so you never scroll past the same photos again."
        android:textColor="@color/on_surface_variant"
        android:textSize="14sp" />

    <!-- The "phone screen" demo surface -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginTop="20dp"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/onboard_screen_bg"
            android:padding="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <com.google.android.material.progressindicator.LinearProgressIndicator
                    android:id="@+id/pbCurated"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:max="100"
                    android:progress="0"
                    app:trackCornerRadius="4dp"
                    app:trackThickness="6dp"
                    app:indicatorColor="@color/check_green"
                    app:trackColor="@color/surface_variant" />

                <TextView
                    android:id="@+id/tvPct"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="10dp"
                    android:text="0% curated"
                    android:textColor="@color/check_green"
                    android:textSize="12sp" />
            </LinearLayout>

            <TextView
                android:id="@+id/tvCaption"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:minHeight="40dp"
                android:gravity="center"
                android:lineSpacingExtra="2dp"
                android:text="Press play to see how curating works."
                android:textColor="@color/on_surface_variant"
                android:textSize="13sp" />

            <LinearLayout
                android:id="@+id/demoStack"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:orientation="vertical" />

            <!-- Floating confirmation shown briefly after a demo delete -->
            <TextView
                android:id="@+id/tvDeletedToast"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="14dp"
                android:background="@drawable/teaser_bar_bg"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingTop="8dp"
                android:paddingBottom="8dp"
                android:text="Deleted photos you didn't want to keep"
                android:textColor="@color/on_surface"
                android:textSize="12sp"
                android:visibility="gone" />
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- Transport controls (hidden in the mandatory first-run mode) -->
    <LinearLayout
        android:id="@+id/controlsRow"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="14dp"
        android:orientation="horizontal"
        android:gravity="center">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnRewind"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="8dp"
            android:text="Rewind" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnPlay"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="8dp"
            android:text="Play" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnPause"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Pause" />
    </LinearLayout>

    <!-- Replaces the old "Get started": tick to never auto-show the demo again -->
    <CheckBox
        android:id="@+id/cbDontShowAgain"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="14dp"
        android:layout_marginBottom="4dp"
        android:text="Don't show again"
        android:textColor="@color/on_surface"
        android:textSize="15sp"
        android:buttonTint="@color/primary" />
    </LinearLayout>

    <!-- Close (✕) — appears at the end of the mandatory run, or always in replay -->
    <TextView
        android:id="@+id/btnCloseDemo"
        android:layout_width="44dp"
        android:layout_height="44dp"
        android:layout_gravity="top|end"
        android:layout_marginTop="6dp"
        android:layout_marginEnd="8dp"
        android:gravity="center"
        android:text="✕"
        android:textColor="@color/on_surface"
        android:textSize="22sp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:contentDescription="Close"
        android:visibility="gone" />

    <!-- Floating finger that "taps" the Delete / Hide buttons during the demo -->
    <TextView
        android:id="@+id/tapFinger"
        android:layout_width="44dp"
        android:layout_height="44dp"
        android:gravity="center"
        android:text="👆"
        android:textSize="30sp"
        android:elevation="12dp"
        android:visibility="invisible" />
</FrameLayout>
