<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:fitsSystemWindows="true">

    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/appBarLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/surface"
        android:fitsSystemWindows="true"
        app:elevation="4dp">

        <!-- PINNED, like every row below it. No child of this AppBarLayout declares
             layout_scrollFlags, so the whole header is fixed: the top strip is read-only and all
             movement happens in the photo list. A collapsing toolbar is the more common Android
             idiom, but here it slid up under the status bar mid-scroll and read as unstable. -->
        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="@color/surface"
            app:titleTextColor="@color/on_surface"
            app:subtitleTextColor="@color/on_surface_variant"
            app:title="@string/app_name" />

        <!-- Sort chip row — sits above the type cards (toolbar subtitle is reserved for progress).
             PINNED: no layout_scrollFlags, so it stays put while the list scrolls. An AppBarLayout
             child without flags is fixed; children WITH flags must be declared before those without,
             which is why the scrolling Toolbar stays first. Keeps the "Came from" label visible
             exactly when you're deep in a month and most likely to want it. -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="10dp"
            android:paddingEnd="10dp"
            android:paddingTop="4dp"
            android:paddingBottom="4dp"
            android:background="@color/surface">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSort"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Oldest first"
                android:textSize="13sp"
                android:minHeight="0dp"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:paddingTop="4dp"
                android:paddingBottom="4dp"
                app:icon="@drawable/ic_sort"
                app:iconSize="16dp" />

            <!-- Previous explored month — INFORMATIONAL ONLY (phase 1, see DESIGN_DEBATES Topic 1).
                 Deliberately plain text: no chip background, no arrow glyph, not clickable — an
                 arrow or pill on untappable text is a false affordance. -->
            <TextView
                android:id="@+id/tvPrevMonth"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="10dp"
                android:textSize="12sp"
                android:textColor="@color/on_surface_variant"
                android:maxLines="1"
                android:ellipsize="end"
                android:gravity="end"
                android:visibility="gone" />
        </LinearLayout>

        <!-- Stat cards row: Photos / Videos / PDFs — PINNED alongside the sort row (see above). -->
        <LinearLayout
            android:id="@+id/settingsBar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:paddingTop="6dp"
            android:paddingBottom="6dp"
            android:background="@color/surface">

            <include
                android:id="@+id/cardPhoto"
                layout="@layout/item_stat_chip"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="6dp" />

            <include
                android:id="@+id/cardVideo"
                layout="@layout/item_stat_chip"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="6dp" />

            <include
                android:id="@+id/cardAudio"
                layout="@layout/item_stat_chip"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="6dp" />

            <include
                android:id="@+id/cardPdf"
                layout="@layout/item_stat_chip"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1" />

        </LinearLayout>

    </com.google.android.material.appbar.AppBarLayout>

    <!-- FrameLayout carries the AppBar scroll behaviour; sticky header overlays the RecyclerView -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recyclerView"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clipToPadding="false"
            android:padding="2dp"
            android:scrollbars="vertical" />

        <!-- Sticky header — pins year + month context at top as the user scrolls -->
        <LinearLayout
            android:id="@+id/stickyHeader"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="top"
            android:orientation="vertical"
            android:elevation="6dp"
            android:visibility="gone">

            <!-- Sticky year row -->
            <LinearLayout
                android:id="@+id/stickyYearRow"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@color/surface_variant"
                android:paddingStart="14dp"
                android:paddingEnd="16dp"
                android:clickable="true"
                android:focusable="true">

                <TextView
                    android:id="@+id/tvStickyYearArrow"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="▼"
                    android:textSize="13sp"
                    android:textColor="@color/primary"
                    android:layout_marginEnd="12dp" />

                <TextView
                    android:id="@+id/tvStickyYear"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="2023"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:textColor="@color/on_surface" />

                <TextView
                    android:id="@+id/tvStickyYearStats"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="1,234 · 4.2 GB"
                    android:textSize="12sp"
                    android:textColor="@color/on_surface_variant" />
            </LinearLayout>

            <!-- Sticky month row -->
            <LinearLayout
                android:id="@+id/stickyMonthRow"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@color/surface"
                android:paddingStart="28dp"
                android:paddingEnd="12dp"
                android:clickable="true"
                android:focusable="true"
                android:visibility="gone">

                <TextView
                    android:id="@+id/tvStickyMonthArrow"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="▼"
                    android:textSize="11sp"
                    android:textColor="@color/primary"
                    android:layout_marginEnd="10dp" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tvStickyMonth"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="January 2024"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:textColor="@color/on_surface" />

                    <TextView
                        android:id="@+id/tvStickyMonthStats"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="45 items · 1.2 GB"
                        android:textSize="11sp"
                        android:textColor="@color/on_surface_variant" />
                </LinearLayout>
            </LinearLayout>

            <!-- Sticky sub-group row (Camera & Others / WhatsApp) -->
            <LinearLayout
                android:id="@+id/stickySubRow"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@color/background"
                android:paddingStart="44dp"
                android:paddingEnd="12dp"
                android:clickable="true"
                android:focusable="true"
                android:visibility="gone">

                <TextView
                    android:id="@+id/tvStickySubArrow"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="▼"
                    android:textSize="10sp"
                    android:textColor="@color/primary"
                    android:layout_marginEnd="8dp" />

                <TextView
                    android:id="@+id/tvStickySubLabel"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:textColor="@color/on_surface" />

                <TextView
                    android:id="@+id/tvStickySubStats"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="11sp"
                    android:textColor="@color/on_surface_variant" />

            </LinearLayout>
        </LinearLayout>

    </FrameLayout>

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_margin="16dp"
        android:orientation="vertical"
        android:gravity="center_horizontal">

        <com.google.android.material.floatingactionbutton.FloatingActionButton
            android:id="@+id/fabJumpSwap"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:src="@drawable/ic_swap"
            android:visibility="gone"
            app:backgroundTint="@color/surface_variant"
            app:fabSize="mini"
            android:contentDescription="Jump to other position" />

        <com.google.android.material.floatingactionbutton.FloatingActionButton
            android:id="@+id/fabScrollToTop"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:src="@android:drawable/arrow_up_float"
            android:visibility="gone"
            app:tint="@android:color/white"
            app:backgroundTint="@color/primary"
            android:contentDescription="Scroll to top" />

    </LinearLayout>

    <ProgressBar
        android:id="@+id/progressBar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:visibility="gone" />

    <TextView
        android:id="@+id/tvEmpty"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:gravity="center"
        android:text="@string/no_photos"
        android:textSize="16sp"
        android:textColor="@color/on_surface_variant"
        android:visibility="gone" />

    <!-- Pinned "Hide month" bar — appears when the month in view has been fully reviewed,
         so the action is always reachable without scrolling to the bottom of the month. -->
    <LinearLayout
        android:id="@+id/hideMonthBarContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingBottom="16dp"
        android:elevation="6dp"
        android:visibility="gone">

        <TextView
            android:id="@+id/coachHideTip"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="10dp"
            android:background="@drawable/coach_bubble_bg"
            android:padding="12dp"
            android:text="You've reviewed this month — tap to hide and remove it from this app. Your files are never deleted; they stay in your phone's gallery. Find it again under Hidden months."
            android:textColor="@color/on_surface"
            android:textSize="13sp"
            android:lineSpacingExtra="2dp"
            android:visibility="gone" />

        <!-- Teaser state: shown (muted) while a reviewed month hasn't been scrolled to its end,
             nudging the user down to where Hide lives. Becomes btnHideMonthBar at the end. -->
        <LinearLayout
            android:id="@+id/teaserHideHint"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@drawable/teaser_bar_bg"
            android:minHeight="48dp"
            android:paddingStart="16dp"
            android:paddingEnd="6dp"
            android:paddingTop="6dp"
            android:paddingBottom="6dp"
            android:visibility="gone">

            <LinearLayout
                android:id="@+id/teaserChevrons"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:layout_marginEnd="14dp">
                <TextView android:id="@+id/chev1"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="▼" android:textSize="15sp" android:textStyle="bold"
                    android:includeFontPadding="false" android:lineSpacingMultiplier="0.85"
                    android:textColor="@color/hide_button_yellow" />
                <TextView android:id="@+id/chev2"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="▼" android:textSize="15sp" android:textStyle="bold"
                    android:includeFontPadding="false" android:lineSpacingMultiplier="0.85"
                    android:textColor="@color/hide_button_yellow" />
                <TextView android:id="@+id/chev3"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="▼" android:textSize="15sp" android:textStyle="bold"
                    android:includeFontPadding="false" android:lineSpacingMultiplier="0.85"
                    android:textColor="@color/hide_button_yellow" />
            </LinearLayout>

            <TextView
                android:id="@+id/tvTeaserText"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Delete junk as you scroll back and forth — hide the month at the end"
                android:textColor="@color/hide_button_yellow"
                android:textStyle="bold"
                android:textSize="14sp"
                android:lineSpacingExtra="2dp" />

            <ImageButton
                android:id="@+id/btnTeaserDismiss"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@drawable/ic_close"
                android:tint="@color/on_surface_variant"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Dismiss hint" />
        </LinearLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnHideMonthBar"
            style="@style/Widget.Material3.Button"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Hide month"
            android:textColor="@android:color/white"
            app:icon="@drawable/ic_check"
            app:iconTint="@android:color/white"
            app:backgroundTint="@color/primary"
            app:cornerRadius="24dp" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/selectionBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:orientation="vertical"
        android:background="@color/selection_bar"
        android:padding="12dp"
        android:elevation="8dp"
        android:visibility="gone">
        <TextView
            android:id="@+id/tvSelectionCount"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:textSize="15sp"
            android:textStyle="bold"
            android:textColor="@color/on_surface"
            android:text="0 selected" />
        <!-- Icon actions (shared set: Share · Rename · Switch Album · Show in gallery · Delete).
             Rename + Show-in-gallery show only on a single selection; delete is filled red, right-aligned. -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnShareSelected"
                style="@style/Widget.Material3.Button.IconButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:icon="@drawable/ic_share"
                app:iconTint="@color/on_surface"
                android:contentDescription="Share"
                android:tooltipText="Share" />
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnRenameSelected"
                style="@style/Widget.Material3.Button.IconButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:icon="@drawable/ic_rename"
                app:iconTint="@color/on_surface"
                android:contentDescription="Rename"
                android:tooltipText="Rename" />
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnMoveSelected"
                style="@style/Widget.Material3.Button.IconButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:icon="@drawable/ic_swap"
                app:iconTint="@color/on_surface"
                android:contentDescription="Switch album"
                android:tooltipText="Switch album" />
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnGallerySelected"
                style="@style/Widget.Material3.Button.IconButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:icon="@drawable/ic_open_gallery"
                app:iconTint="@color/on_surface"
                android:contentDescription="Show in gallery"
                android:tooltipText="Show in gallery" />
            <Space
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1" />
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnDeleteSelected"
                style="@style/Widget.Material3.Button.IconButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:icon="@drawable/ic_delete"
                app:iconTint="@color/delete_red"
                android:contentDescription="Delete"
                android:tooltipText="Delete" />
        </LinearLayout>
    </LinearLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>